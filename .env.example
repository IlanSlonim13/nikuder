# WhatsApp group IDs (get these from the bot's console log on first run)
# Comma-separated list of source group IDs
SOURCE_GROUP_IDS=120363012345678901@g.us,120363098765432101@g.us
TARGET_GROUP_ID=120363011111111111@g.us

# Language settings (ISO 639-1 codes)
# Source language to detect and process (he, ar, ru, zh, ja, ko, etc.)
SOURCE_LANG=he
# Target language to translate into (en, es, fr, de, pt, etc.)
TARGET_LANG=en

# Options
FORWARD_NON_SOURCE_LANG=false
ADD_ORIGINAL_TEXT=true
BOT_TAG=[ניקוד]
LOG_LEVEL=info

# Windows: if Chromium download fails, set path to your Chrome installation
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
